{
  "crons": [
    {
      "path": "/api/draft-posts",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/pipeline?type=trigger",
      "schedule": "0 14 * * *"
    }
  ],
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/api/sitemap" },
    { "source": "/preview", "destination": "/" },
    { "source": "/match/:matchId", "destination": "/" },
    { "source": "/about", "destination": "/" },
    { "source": "/release-notes", "destination": "/" },
    { "source": "/tournaments", "destination": "/" },
    { "source": "/tournament/:seriesId", "destination": "/" },
    { "source": "/calendar", "destination": "/" },
    { "source": "/analytics", "destination": "/" },
    { "source": "/news", "destination": "/" },
    { "source": "/glossary", "destination": "/" },
    { "source": "/glossary/:term", "destination": "/" },
    { "source": "/teams", "destination": "/" },
    { "source": "/teams/:slug", "destination": "/" },
    { "source": "/articles", "destination": "/" },
    { "source": "/articles/:slug", "destination": "/" },
    { "source": "/heroes", "destination": "/" },
    { "source": "/heroes/:slug", "destination": "/" },
    { "source": "/admin/coverage", "destination": "/" },
    { "source": "/admin/review/:jobId", "destination": "/" },
    { "source": "/admin/vod-urls", "destination": "/" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        {
          "key": "Content-Security-Policy-Report-Only",
          "value": "default-src 'self'; script-src 'self' https://www.googletagmanager.com https://va.vercel-scripts.com 'unsafe-inline'; style-src 'self' https://fonts.googleapis.com 'unsafe-inline'; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://www.google-analytics.com https://region1.google-analytics.com https://vitals.vercel-insights.com; frame-ancestors 'none'"
        }
      ]
    }
  ]
}
